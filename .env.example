# ============================================================
# hermes-nexttalk-bot — environment variable reference
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Anthropic (required)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# Nextcloud credentials
#
# Two naming conventions are supported — use whichever suits
# your stack.  If both are set for the same field, the
# NEXTCLOUD_* variant takes priority over NC_*.
#
# Style A — short NC_* names (original convention)
# ------------------------------------------------------------
NC_URL=https://nextcloud.example.com
NC_USER=botuser
NC_PASS=app-password-here
# NC_PASSWORD is an alias for NC_PASS — only one is needed
# NC_PASSWORD=app-password-here

# ------------------------------------------------------------
# Style B — longer NEXTCLOUD_* names (alternative convention)
# ------------------------------------------------------------
# NEXTCLOUD_URL=https://nextcloud.example.com
# NEXTCLOUD_USERNAME=botuser
# NEXTCLOUD_APP_PASSWORD=app-password-here

# ------------------------------------------------------------
# Telegram notifications (optional)
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Web UI
# ------------------------------------------------------------
# Password for the built-in web UI (default: changeme)
WEBUI_PASSWORD=changeme
